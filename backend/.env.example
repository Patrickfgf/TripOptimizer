# ── Runtime — the deployed API reads these ───────────────────────────────
# CORS allowlist: comma-separated browser origins allowed to call the API.
# REQUIRED in production: set to your deployed frontend origin (e.g. the Vercel URL).
# Unset -> defaults to http://localhost:5173 and the app logs a startup warning.
FRONTEND_ORIGINS=http://localhost:5173

# Optional path overrides (default to backend/data/*). Normally leave unset.
# TRIPOPTIMIZER_SNAPSHOT=./data/fares_snapshot.parquet
# TRIPOPTIMIZER_AIRPORTS_CSV=./data/airports_sample.csv

# ── Offline ingestion only — NOT read by the serving API ─────────────────
# Travelpayouts Data API token, used solely by
#   uv run python -m tripoptimizer.ingestion.build_snapshot ...
# to (re)generate data/fares_snapshot.parquet. The live API never needs it:
# it serves the committed snapshot and falls back to synthetic fares.
TRAVELPAYOUTS_TOKEN=
# Travelpayouts market (cache is market-specific; default 'ru' is sparse for EU). Use an EU market.
TRAVELPAYOUTS_MARKET=es
