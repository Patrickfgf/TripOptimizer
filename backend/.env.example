# ── Runtime — the deployed API reads these ───────────────────────────────
# CORS allowlist: comma-separated browser origins allowed to call the API.
# REQUIRED in production: set to your deployed frontend origin (e.g. the Vercel URL).
# Unset -> defaults to http://localhost:5173 and the app logs a startup warning.
FRONTEND_ORIGINS=http://localhost:5173

# On-demand live fares. With a Travelpayouts token the serving API fetches REAL fares
# from the month-matrix endpoint (one call warms a whole month) for cells the committed
# snapshot lacks. UNSET -> the API serves ONLY the committed snapshot; there is NO
# synthetic fallback, so a route with no real fare is reported as unavailable, never
# fabricated. (The offline snapshot builder also reads this token.)
TRAVELPAYOUTS_TOKEN=

# Optional durable cache for on-demand fares: a Neon/Postgres DSN (prefer the DIRECT,
# non-pooler DSN for a single worker). Set -> fetched fares persist across restarts.
# Unset -> an in-process dict cache is used (resets on restart). Only used with the token.
# DATABASE_URL=

# Optional: days before a cached on-demand fare is re-fetched. Must be in (0, 365];
# defaults to 7 (matches Travelpayouts' freshness window). Uncomment to override.
# FARE_CACHE_TTL_DAYS=7

# Optional path overrides (default to backend/data/*). Normally leave unset.
# TRIPOPTIMIZER_SNAPSHOT=./data/fares_snapshot.parquet
# TRIPOPTIMIZER_AIRPORTS_CSV=./data/airports_sample.csv

# ── Offline ingestion only — NOT read by the serving API ─────────────────
# Travelpayouts market for the OFFLINE snapshot builder (per-date endpoint):
#   uv run python -m tripoptimizer.ingestion.build_snapshot ...
# The month-matrix serving path does not use it. EU markets are denser than the default.
TRAVELPAYOUTS_MARKET=es
